CHATWOOT_URL=https://chatwoot.odontotec.easypanel.host
CHATWOOT_API_TOKEN=xxx
CHATWOOT_ACCOUNT_ID=1
BOT_OFF_LABEL=bot-off

CALCOM_URL=https://calcom.odontotec.easypanel.host
CALCOM_API_KEY=xxx
CALCOM_EVENTS={"general":6008308,"ortodoncia":6008309,"endodoncia":6008310,"cirugia":6008311,"protesis":6008312,"odontopediatria":6008313}

# OpenRouter (preferido) O OpenAI directo — solo uno es necesario
OPENROUTER_API_KEY=xxx
# OPENAI_API_KEY=xxx
OPENAI_MODEL=openai/gpt-4o-mini

# Email confirmaciones de citas
# Gmail: activar "App Passwords" en cuenta Google → usar como SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=odontotec@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=Odontotec <odontotec@gmail.com>
EMAIL_CLINIC=contactoodontotec@gmail.com

PORT=8000
MAX_HISTORY=20
TIMEZONE=America/Santo_Domingo
REMINDER_HOUR=20

# --- Dentidesk (agenda real) ---
# API (cuenta de servicio del proveedor CERO.AI) — solo LECTURA hasta la simulación
DENTIDESK_BASE=https://app.dentidesk.com/api
DENTIDESK_USER=produccion@cero.ai
DENTIDESK_PASS=
DENTIDESK_LOCATION=214
# Login web (cuenta staff) — solo para Playwright (crear/mover citas)
DENTIDESK_WEB_USER=h.geronimo
DENTIDESK_WEB_PASS=
# CANDADO de escritura: dejar VACÍO/0 en prod. Solo =1 en el campo de simulación autorizado.
DENTIDESK_ALLOW_WRITES=
# DENTIDESK_PW_HEADLESS=1   # navegador Playwright sin ventana (default)
